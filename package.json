{
  "name": "wts-report",
  "displayName": "wts-report",
  "description": "AI-powered timesheet reporting extension. Automatically detect git changes and generate timesheet reports with AI summaries.",
  "version": "0.0.8",
  "engines": {
    "node": ">=20",
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:extension.startExtension"
  ],
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "llm-checking",
        "name": "llm-checking",
        "description": "A participant for checking LLM responses"
      }
    ],
    "commands": [
      {
        "command": "extension.startExtension",
        "title": "WTS Report"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile:ts": "tsc -p ./",
    "compile:copy": "cp ui/dist/index.html out/index.html && cp ui/dist/main.js out/main.js",
    "ui:build": "cd ui && pnpm install && pnpm run build && cd ..",
    "build:all": "pnpm run compile:ts && pnpm run ui:build && pnpm run compile:copy",
    "compile": "pnpm run build:all",
    "pretest": "pnpm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "@webpack-cli/serve": "^3.0.1",
    "chai": "^6.2.2",
    "eslint": "^9.39.3",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "sinon": "^22.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^9.0.0"
  }
}
